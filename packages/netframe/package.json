{
  "name": "netframe",
  "version": "0.1.0",
  "description": "A cyberpunk-themed CSS component library",
  "type": "module",
  "license": "GPL-3.0-only",
  "author": "Cybear Technologies",
  "keywords": ["css", "cyberpunk", "ui", "design-system", "sass", "scss"],
  "homepage": "https://github.com/Cybear Technologies/NetFrame#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cybear Technologies/NetFrame.git",
    "directory": "packages/netframe"
  },
  "exports": {
    ".": {
      "style": "./dist/netframe.css",
      "sass": "./dist/scss/netframe.scss"
    },
    "./min": {
      "style": "./dist/netframe.min.css"
    },
    "./themes": {
      "style": "./dist/themes.css",
      "sass": "./dist/scss/themes/themes.scss"
    },
    "./themes/min": {
      "style": "./dist/themes.min.css"
    },
    "./scss/*": "./dist/scss/*"
  },
  "main": "./dist/netframe.css",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "dev": "tsx scripts/build.ts --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.7",
    "postcss": "^8.5.13",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
